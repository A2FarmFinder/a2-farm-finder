---
interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Find farms, CSAs, and farmers markets around Ann Arbor, Chelsea, Dexter, Saline, and Manchester.' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,600;9..144,700&family=Figtree:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-2359822306567746" crossorigin="anonymous"></script>
    <title>{title} | A2 Farm Finder</title>
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href="/">
        <span class="brand-mark">🌱</span> A2 Farm Finder
      </a>
      <nav>
        <a href="/farms">Farms &amp; CSAs</a>
        <a href="/markets">Farmers Markets</a>
        <a href="/blog">Blog</a>
        <a href="/recipes">Recipes</a>
        <a href="/kids">Kids</a>
        <a href="/about">About</a>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer class="site-footer">
      <div class="footer-inner">
        <p class="footer-brand"><span class="brand-mark">🌱</span> A2 Farm Finder</p>
        <p>A directory of farms, CSAs, and farmers markets across Washtenaw County.</p>
        <p class="footer-links">
          <a href="/about">About</a> &middot; <a href="/privacy">Privacy Policy</a> &middot;
          <a href="https://www.facebook.com/profile.php?id=61590713406515" target="_blank" rel="noopener noreferrer" aria-label="A2 Farm Finder on Facebook">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor" style="vertical-align:middle; margin-left:4px;">
              <path d="M24 12.073C24 5.405 18.627 0 12 0S0 5.405 0 12.073C0 18.1 4.388 23.094 10.125 24v-8.437H7.078v-3.49h3.047V9.413c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953h-1.514c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.49h-2.796V24C19.612 23.094 24 18.1 24 12.073z"/>
            </svg>
          </a>
        </p>
      </div>
    </footer>

    <script>
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('visible');
              observer.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.08, rootMargin: '0px 0px -30px 0px' }
      );
      document.querySelectorAll('.fade-in').forEach((el) => observer.observe(el));
    </script>

    <style is:global>
      :root {
        color-scheme: light;
        --green-dark: #2f5233;
        --green-mid: #4a7c4e;
        --green-pale: #e7f0e3;
        --gold: #e0a458;
        --gold-dark: #c8853a;
        --cream: #fbfaf5;
        --ink: #2a2e22;
        --muted: #6b7a6b;
        --border: #e6e2d4;
        font-family: 'Figtree', system-ui, sans-serif;
      }
      * { box-sizing: border-box; }
      body {
        margin: 0;
        line-height: 1.65;
        color: var(--ink);
        background: var(--cream);
      }
      h1, h2, h3 {
        font-family: 'Fraunces', Georgia, serif;
        line-height: 1.2;
        letter-spacing: -0.01em;
      }
      a { color: var(--green-dark); }

      /* ── Header ── */
      .site-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 1rem 1.5rem;
        background: var(--green-dark);
        color: #fff;
        flex-wrap: wrap;
        gap: 0.75rem;
        position: sticky;
        top: 0;
        z-index: 10;
        box-shadow: 0 2px 12px rgba(0,0,0,0.18);
      }
      .site-header .brand {
        font-family: 'Fraunces', Georgia, serif;
        font-weight: 700;
        font-size: 1.35rem;
        color: #fff;
        text-decoration: none;
        display: flex;
        align-items: center;
        gap: 0.4rem;
      }
      .brand-mark { font-size: 1.2em; }
      .site-header nav { display: flex; flex-wrap: wrap; gap: 0.25rem; }
      .site-header nav a {
        color: #f1f5ef;
        text-decoration: none;
        font-weight: 500;
        padding: 0.4rem 0.75rem;
        border-radius: 999px;
        transition: background 0.2s ease;
      }
      .site-header nav a:hover { background: rgba(255,255,255,0.15); }

      /* ── Layout ── */
      main {
        max-width: 1024px;
        margin: 0 auto;
        padding: 2rem 1.5rem 3rem;
      }

      /* ── Footer ── */
      .site-footer { background: var(--green-dark); color: #dfeadf; margin-top: 0; }
      .footer-inner {
        max-width: 1024px;
        margin: 0 auto;
        padding: 2.5rem 1.5rem;
        text-align: center;
      }
      .footer-brand {
        font-family: 'Fraunces', Georgia, serif;
        font-weight: 700;
        font-size: 1.1rem;
        color: #fff;
        margin-bottom: 0.5rem;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.4rem;
      }
      .footer-links a, .site-footer a { color: #fff; }
      .footer-links { margin-top: 0.75rem; font-size: 0.9rem; }

      /* ── [5] Card colored header strips ── */
      .grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 1.25rem; margin-top: 1.5rem; }
      .card {
        border: 1px solid var(--border);
        border-radius: 16px;
        padding: 0 1.5rem 1.5rem;
        background: #fff;
        box-shadow: 0 1px 4px rgba(47,82,51,0.06);
        transition: transform 0.22s ease, box-shadow 0.22s ease, border-color 0.22s ease;
        position: relative;
        overflow: hidden;
      }
      /* Colored header strip at top of each card */
      .card::before {
        content: '';
        display: block;
        height: 6px;
        margin: 0 -1.5rem 1.25rem;
        background: var(--green-pale);
        border-radius: 16px 16px 0 0;
      }
      .card--farm::before   { background: linear-gradient(90deg, var(--green-mid), #6aaa6e); }
      .card--market::before { background: linear-gradient(90deg, var(--gold), #f0c070); }
      .card--blog::before   { background: linear-gradient(90deg, #7a9e7e, #a0bf9a); }
      .card--recipe::before { background: linear-gradient(90deg, #c97b4b, var(--gold)); }
      /* Bottom accent line on hover */
      .card::after {
        content: '';
        position: absolute;
        bottom: 0; left: 0;
        width: 100%; height: 3px;
        background: linear-gradient(90deg, var(--green-mid), var(--gold));
        transform: scaleX(0);
        transform-origin: left;
        transition: transform 0.25s ease;
        border-radius: 0 0 16px 16px;
      }
      a.card { display: block; text-decoration: none; color: inherit; }
      a.card:hover, .card.hoverable:hover {
        transform: translateY(-4px) scale(1.01);
        box-shadow: 0 12px 32px rgba(47,82,51,0.14);
        border-color: var(--green-mid);
      }
      a.card:hover::after, .card.hoverable:hover::after { transform: scaleX(1); }
      .card h3 { margin-top: 0; margin-bottom: 0.4rem; font-size: 1.2rem; }
      .card .town { color: var(--muted); font-size: 0.9rem; margin: 0 0 0.5rem; }
      .card .icon { font-size: 1.6rem; margin-bottom: 0.5rem; display: inline-block; }

      .tag {
        display: inline-block;
        background: var(--green-pale);
        color: var(--green-dark);
        border-radius: 999px;
        padding: 0.2rem 0.7rem;
        font-size: 0.8rem;
        font-weight: 500;
        margin: 0 0.3rem 0.3rem 0;
      }
      .tag.gold { background: #fbe9d2; color: var(--gold-dark); }
      .card.featured {
        border-color: var(--gold);
        background: linear-gradient(180deg, #fffaf0, #ffffff);
        position: relative;
      }
      .sponsored-badge {
        position: absolute;
        top: 0.9rem; right: 1rem;
        background: var(--gold);
        color: var(--green-dark);
        font-size: 0.7rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.04em;
        padding: 0.2rem 0.6rem;
        border-radius: 999px;
      }

      /* ── Hero ── */
      .hero {
        background: linear-gradient(145deg, #1a3320 0%, #2f5233 45%, #3d6b42 100%);
        color: #fff;
        border-radius: 20px;
        padding: 4rem 2.5rem 0;
        margin-bottom: 0;
        position: relative;
        overflow: hidden;
        min-height: 420px;
        display: flex;
        flex-direction: column;
        justify-content: center;
      }
      .hero::before {
        content: '';
        position: absolute;
        inset: 0;
        background-image: radial-gradient(circle, rgba(255,255,255,0.06) 1px, transparent 1px);
        background-size: 28px 28px;
        pointer-events: none;
      }
      .hero::after {
        content: '';
        position: absolute;
        top: -100px; right: -100px;
        width: 420px; height: 420px;
        background: radial-gradient(circle, rgba(224,164,88,0.15) 0%, transparent 65%);
        pointer-events: none;
      }
      .hero-content {
        position: relative;
        z-index: 1;
        padding-bottom: 2rem;
      }
      .hero h1 {
        margin: 0 0 1rem;
        font-size: clamp(2rem, 5vw, 3.2rem);
        color: #fff;
        max-width: 22rem;
        text-shadow: 0 2px 16px rgba(0,0,0,0.2);
      }
      .hero p {
        max-width: 36rem;
        font-size: 1.1rem;
        color: #d0e8ce;
        margin: 0;
      }
      .hero .hero-actions {
        margin-top: 2rem;
        display: flex;
        gap: 0.75rem;
        flex-wrap: wrap;
      }

      /* ── [1] Hero landscape SVG ── */
      .hero-landscape {
        position: relative;
        z-index: 1;
        margin: 0 -2.5rem;
        line-height: 0;
        margin-top: auto;
      }
      .hero-landscape svg { display: block; width: 100%; }

      /* ── Buttons ── */
      .btn {
        display: inline-block;
        padding: 0.75rem 1.5rem;
        border-radius: 999px;
        font-weight: 600;
        text-decoration: none;
        font-size: 0.95rem;
        transition: transform 0.18s ease, box-shadow 0.18s ease, background 0.18s ease;
      }
      .btn-primary {
        background: var(--gold);
        color: var(--green-dark);
        box-shadow: 0 2px 12px rgba(224,164,88,0.4);
      }
      .btn-primary:hover { background: #eab46a; box-shadow: 0 6px 20px rgba(224,164,88,0.55); }
      .btn-secondary {
        background: rgba(255,255,255,0.1);
        color: #fff;
        border: 1px solid rgba(255,255,255,0.4);
        backdrop-filter: blur(4px);
      }
      .btn-secondary:hover { background: rgba(255,255,255,0.2); }
      .btn:hover { transform: translateY(-2px); }

      /* ── [4] Stats bar ── */
      .stats-bar {
        display: flex;
        align-items: center;
        justify-content: center;
        flex-wrap: wrap;
        gap: 0 2rem;
        background: var(--green-dark);
        color: #fff;
        padding: 1rem 1.5rem;
        margin: 0 0 0;
        border-radius: 0 0 16px 16px;
      }
      .stat {
        display: flex;
        flex-direction: column;
        align-items: center;
        padding: 0.4rem 0;
      }
      .stat-num {
        font-family: 'Fraunces', Georgia, serif;
        font-size: 1.6rem;
        font-weight: 700;
        color: var(--gold);
        line-height: 1;
      }
      .stat-label {
        font-size: 0.75rem;
        color: #b8d4b8;
        text-transform: uppercase;
        letter-spacing: 0.06em;
        font-weight: 500;
        white-space: nowrap;
      }
      .stats-divider {
        color: rgba(255,255,255,0.2);
        font-size: 1.5rem;
        line-height: 1;
        display: flex;
        align-items: center;
      }

      /* ── Seasonal strip ── */
      .seasonal-strip {
        background: linear-gradient(90deg, var(--green-pale), #f0f7ee);
        border: 1px solid #c8dfc4;
        border-radius: 14px;
        padding: 1rem 1.5rem;
        margin-top: 1.5rem;
        display: flex;
        align-items: center;
        gap: 1rem;
        flex-wrap: wrap;
      }
      .seasonal-strip .strip-label {
        font-weight: 700;
        color: var(--green-dark);
        font-size: 0.9rem;
        white-space: nowrap;
        display: flex;
        align-items: center;
        gap: 0.4rem;
      }
      .seasonal-strip .strip-items { display: flex; flex-wrap: wrap; gap: 0.4rem; }
      .seasonal-strip .strip-pill {
        background: #fff;
        border: 1px solid #c0d9bb;
        color: var(--green-dark);
        border-radius: 999px;
        padding: 0.2rem 0.75rem;
        font-size: 0.82rem;
        font-weight: 500;
        text-decoration: none;
        transition: background 0.15s ease, border-color 0.15s ease;
      }
      .seasonal-strip .strip-pill:hover { background: var(--green-pale); border-color: var(--green-mid); }

      /* ── [2] Wave dividers ── */
      .wave-divider {
        margin: 0 -1.5rem;
        line-height: 0;
        overflow: hidden;
      }
      .wave-divider svg { display: block; width: 100%; }

      /* ── [3] Alternating section bands ── */
      .section-band {
        margin: 0 -1.5rem;
        padding: 2.5rem 1.5rem 3rem;
      }
      .section-band--green {
        background: linear-gradient(180deg, #edf5ea 0%, #e4f0e0 100%);
      }
      .section-band--cream {
        background: var(--cream);
      }

      /* ── Section heading ── */
      .section-heading {
        display: flex;
        align-items: baseline;
        justify-content: space-between;
        margin-top: 0;
        margin-bottom: 0;
        flex-wrap: wrap;
        gap: 0.5rem;
      }
      .section-heading h2 { margin: 0; font-size: 1.6rem; }
      .section-heading a { font-weight: 600; text-decoration: none; white-space: nowrap; }
      .section-heading a:hover { text-decoration: underline; }

      /* ── Page intro ── */
      .page-intro h1 { font-size: clamp(1.8rem, 4vw, 2.6rem); margin-bottom: 0.5rem; }
      .page-intro p { color: var(--muted); font-size: 1.05rem; max-width: 42rem; }

      /* ── Scroll fade-in ── */
      .fade-in {
        opacity: 0;
        transform: translateY(22px);
        transition: opacity 0.6s ease, transform 0.6s ease;
      }
      .fade-in.visible { opacity: 1; transform: translateY(0); }

      /* ── Mobile ── */
      @media (max-width: 600px) {
        /* Compact header nav */
        .site-header {
          padding: 0.75rem 1rem;
          gap: 0.5rem;
        }
        .site-header .brand { font-size: 1.1rem; }
        .site-header nav { gap: 0.15rem; }
        .site-header nav a {
          font-size: 0.78rem;
          padding: 0.3rem 0.55rem;
        }

        /* Smaller hero on mobile */
        .hero {
          border-radius: 14px;
          padding: 2.5rem 1.25rem 0;
          min-height: 320px;
        }
        .hero h1 { font-size: 1.9rem; max-width: 100%; }
        .hero p { font-size: 1rem; }
        .hero .hero-actions { margin-top: 1.25rem; }
        .btn { padding: 0.65rem 1.1rem; font-size: 0.9rem; }

        /* Stats bar 2x2 grid on mobile */
        .stats-bar {
          display: grid;
          grid-template-columns: 1fr 1fr;
          gap: 0.75rem 0;
          padding: 1.25rem 1rem;
          border-radius: 0 0 12px 12px;
        }
        .stats-divider { display: none; }
        .stat-num { font-size: 1.3rem; }
        .stat-label { font-size: 0.7rem; }

        /* Seasonal strip compact */
        .seasonal-strip { padding: 0.75rem 1rem; gap: 0.5rem; }

        /* Section bands flush on mobile */
        .section-band { margin: 0 -1rem; padding: 1.75rem 1rem 2rem; }
        .wave-divider { margin: 0 -1rem; }

        /* Cards single column */
        .grid { grid-template-columns: 1fr; gap: 1rem; }

        main { padding: 1.5rem 1rem 2rem; }
      }
    </style>
  </body>
</html>
