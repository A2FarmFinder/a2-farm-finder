---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const recipes = (await getCollection('recipes')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const categories = [
  'Breakfast & Brunch',
  'Salads',
  'Mains',
  'Sides',
  'Soups & Stews',
  'Snacks & Appetizers',
  'Desserts',
  'Preserves & Pantry',
] as const;

const byCategory = categories
  .map((cat) => ({
    name: cat,
    recipes: recipes.filter((r) => r.data.category === cat),
  }))
  .filter((group) => group.recipes.length > 0);
---

<Layout title="Recipes" description="Seasonal recipes using fresh produce from Washtenaw County farms and farmers markets.">
  <div class="page-intro">
    <h1>Seasonal Recipes</h1>
    <p>Simple recipes built around what's fresh at your local farm or farmers market. New recipes every Tuesday and Friday.</p>
  </div>

  {byCategory.map((group) => (
    <div class="category-section">
      <div class="section-heading">
        <h2>{group.name}</h2>
      </div>
      <div class="grid">
        {group.recipes.map((recipe) => (
          <a href={`/recipes/${recipe.id}`} class="card hoverable">
            <span class="icon">🍳</span>
            <h3>{recipe.data.title}</h3>
            <p class="town">{recipe.data.season}</p>
            <p>{recipe.data.description}</p>
            <div style="margin-top: 0.75rem; display: flex; flex-wrap: wrap; gap: 0.3rem;">
              {recipe.data.produce.map((item: string) => (
                <span class="tag">{item}</span>
              ))}
            </div>
            <p style="font-size: 0.85rem; color: var(--muted); margin: 0.75rem 0 0;">
              {recipe.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
              {recipe.data.prepTime && <span> &middot; {recipe.data.prepTime}</span>}
              {recipe.data.servings && <span> &middot; {recipe.data.servings}</span>}
            </p>
          </a>
        ))}
      </div>
    </div>
  ))}
</Layout>

<style>
  .category-section {
    margin-top: 2.5rem;
  }
  .category-section:first-of-type {
    margin-top: 1rem;
  }
</style>
