---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { farmIcon } from '../lib/icons';

const farms = await getCollection('farms');
const markets = await getCollection('markets');
const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const month = new Date().getMonth(); // 0-indexed
const monthNames = ['January','February','March','April','May','June','July','August','September','October','November','December'];
const seasonalProduce: Record<number, string[]> = {
  0:  ['Storage squash', 'Root vegetables', 'Greenhouse herbs', 'Dried beans', 'Storage apples'],
  1:  ['Storage carrots', 'Beets', 'Potatoes', 'Greenhouse greens', 'Onions'],
  2:  ['Greenhouse lettuce', 'Spinach', 'Herbs', 'Maple syrup', 'Eggs'],
  3:  ['Asparagus', 'Rhubarb', 'Spinach', 'Radishes', 'Greenhouse tomatoes'],
  4:  ['Asparagus', 'Rhubarb', 'Peas', 'Lettuce', 'Radishes', 'Spinach', 'Herbs'],
  5:  ['Strawberries', 'Asparagus', 'Peas', 'Kale', 'Chard', 'Herbs', 'Scallions', 'Radishes'],
  6:  ['Blueberries', 'Zucchini', 'Green Beans', 'Beets', 'Cucumbers', 'Early Tomatoes', 'Basil', 'Corn'],
  7:  ['Tomatoes', 'Sweet Corn', 'Peaches', 'Peppers', 'Eggplant', 'Melons', 'Basil', 'Beans'],
  8:  ['Apples', 'Winter Squash', 'Late Tomatoes', 'Peppers', 'Sweet Potatoes', 'Garlic'],
  9:  ['Apples', 'Winter Squash', 'Sweet Potatoes', 'Beets', 'Carrots', 'Kale'],
  10: ['Root vegetables', 'Winter Squash', 'Storage Apples', 'Kale', 'Brussels Sprouts'],
  11: ['Storage Squash', 'Root Vegetables', 'Greenhouse Herbs', 'Dried Beans'],
};
const produce = seasonalProduce[month] ?? [];
const monthName = monthNames[month];
---

<Layout title="Home">
  <section class="hero">
    <h1>Find local farms, CSAs &amp; farmers markets near Ann Arbor</h1>
    <p>
      A directory of farms, CSA programs, and farmers markets across
      Washtenaw County &mdash; Ann Arbor, Chelsea, Dexter, Saline,
      Manchester, and beyond.
    </p>
    <div class="hero-actions">
      <a class="btn btn-primary" href="/farms">Browse farms &amp; CSAs</a>
      <a class="btn btn-secondary" href="/markets">Find a farmers market</a>
    </div>
  </section>

  <!-- What's in season this month -->
  {produce.length > 0 && (
    <div class="seasonal-strip fade-in">
      <span class="strip-label">🌿 In season this {monthName}:</span>
      <div class="strip-items">
        {produce.map((item) => (
          <a href="/markets" class="strip-pill">{item}</a>
        ))}
      </div>
    </div>
  )}

  <div class="section-heading fade-in">
    <h2>Latest from the blog</h2>
    <a href="/blog">All posts &rarr;</a>
  </div>
  <div class="grid fade-in">
    {posts.slice(0, 3).map((post) => (
      <a class="card" href={`/blog/${post.id}`}>
        <span class="icon">📰</span>
        <h3>{post.data.title}</h3>
        <p>{post.data.description}</p>
      </a>
    ))}
  </div>

  <div class="section-heading fade-in">
    <h2>Farms &amp; CSAs</h2>
    <a href="/farms">View all {farms.length} &rarr;</a>
  </div>
  <div class="grid fade-in">
    {farms.slice(0, 3).map((farm) => (
      <a class="card" href={`/farms/${farm.id}`}>
        <span class="icon">{farmIcon(farm.data.products)}</span>
        <h3>{farm.data.name}</h3>
        <p class="town">{farm.data.town}</p>
        <p>{farm.data.summary}</p>
      </a>
    ))}
  </div>

  <div class="section-heading fade-in">
    <h2>Farmers Markets</h2>
    <a href="/markets">View all {markets.length} &rarr;</a>
  </div>
  <div class="grid fade-in">
    {markets.map((market) => (
      <a class="card" href="/markets">
        <span class="icon">🧺</span>
        <h3>{market.data.name}</h3>
        <p class="town">{market.data.town}</p>
        <p>{market.data.summary}</p>
      </a>
    ))}
  </div>
</Layout>
