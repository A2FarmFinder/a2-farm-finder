---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { farmIcon } from '../lib/icons';
import { slugify, produceData } from '../data/produce';

function produceLink(item: string): string {
  const slug = slugify(item);
  const exists = produceData.some(p => p.slug === slug);
  return exists ? `/produce/${slug}` : '/markets';
}

const farms = await getCollection('farms');
const markets = await getCollection('markets');
const today = new Date(); today.setHours(0,0,0,0);
const upcomingEvents = (await getCollection('events'))
  .filter(e => (e.data.endDate ?? e.data.date) >= today)
  .sort((a, b) => a.data.date.valueOf() - b.data.date.valueOf());
const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
const recipes = (await getCollection('recipes')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

// Seasonal produce — resolved client-side to avoid baking in build-time month
const seasonalProduce: Record<number, string[]> = {
  0:  ['Storage Squash', 'Root Vegetables', 'Greenhouse Herbs', 'Storage Apples'],
  1:  ['Storage Carrots', 'Beets', 'Potatoes', 'Greenhouse Greens'],
  2:  ['Greenhouse Lettuce', 'Spinach', 'Herbs', 'Maple Syrup'],
  3:  ['Asparagus', 'Rhubarb', 'Spinach', 'Radishes'],
  4:  ['Asparagus', 'Rhubarb', 'Peas', 'Lettuce', 'Herbs'],
  5:  ['Strawberries', 'Asparagus', 'Peas', 'Kale', 'Chard', 'Herbs', 'Scallions', 'Radishes'],
  6:  ['Blueberries', 'Zucchini', 'Green Beans', 'Cucumbers', 'Early Tomatoes', 'Basil', 'Corn'],
  7:  ['Tomatoes', 'Sweet Corn', 'Peaches', 'Peppers', 'Eggplant', 'Melons', 'Basil'],
  8:  ['Apples', 'Winter Squash', 'Late Tomatoes', 'Peppers', 'Sweet Potatoes'],
  9:  ['Apples', 'Winter Squash', 'Sweet Potatoes', 'Beets', 'Carrots', 'Kale'],
  10: ['Root Vegetables', 'Winter Squash', 'Storage Apples', 'Kale'],
  11: ['Storage Squash', 'Root Vegetables', 'Greenhouse Herbs'],
};
// SSG fallback values (overridden client-side)
const produce = seasonalProduce[6];
const monthName = 'this month';
const nextProduce = seasonalProduce[7];
const nextMonthName = 'next month';
// Pass slug lookup to client
const produceSlugMap = Object.fromEntries(produceData.map(p => [p.name, p.slug]));
---

<Layout title="Home">

  <!-- Hero -->
  <section class="hero">
    <div class="hero-content">
      <h1>Find local farms, CSAs, farmers markets &amp; events near Ann Arbor</h1>
      <p>A directory of farms, CSA programs, farmers markets, and local events across Washtenaw County — Ann Arbor, Chelsea, Dexter, Saline, Manchester, and beyond.</p>
      <div class="hero-actions">
        <a class="btn btn-primary" href="/farms">Browse farms &amp; CSAs</a>
        <a class="btn btn-secondary" href="/markets">Find a farmers market</a>
        <a class="btn btn-secondary" href="/events">Find an event</a>
      </div>
    </div>
    <div class="hero-landscape" aria-hidden="true">
      <svg viewBox="0 0 1200 160" preserveAspectRatio="xMidYMax slice" xmlns="http://www.w3.org/2000/svg">
        <path d="M0,95 C180,60 380,82 580,68 C780,54 980,76 1200,70 L1200,160 L0,160 Z" fill="rgba(255,255,255,0.04)"/>
        <path d="M0,112 C200,88 420,106 620,96 C820,86 1020,100 1200,94 L1200,160 L0,160 Z" fill="rgba(255,255,255,0.07)"/>
        <ellipse cx="155" cy="108" rx="24" ry="30" fill="rgba(255,255,255,0.07)"/>
        <ellipse cx="182" cy="104" rx="19" ry="25" fill="rgba(255,255,255,0.09)"/>
        <ellipse cx="130" cy="113" rx="16" ry="21" fill="rgba(255,255,255,0.06)"/>
        <rect x="153" y="128" width="5" height="18" fill="rgba(255,255,255,0.06)"/>
        <rect x="280" y="122" width="3" height="16" rx="1" fill="rgba(255,255,255,0.12)"/>
        <rect x="296" y="122" width="3" height="16" rx="1" fill="rgba(255,255,255,0.12)"/>
        <rect x="312" y="122" width="3" height="16" rx="1" fill="rgba(255,255,255,0.12)"/>
        <rect x="328" y="122" width="3" height="16" rx="1" fill="rgba(255,255,255,0.12)"/>
        <rect x="344" y="122" width="3" height="16" rx="1" fill="rgba(255,255,255,0.12)"/>
        <rect x="360" y="122" width="3" height="16" rx="1" fill="rgba(255,255,255,0.12)"/>
        <line x1="280" y1="126" x2="363" y2="126" stroke="rgba(255,255,255,0.12)" stroke-width="2"/>
        <line x1="280" y1="132" x2="363" y2="132" stroke="rgba(255,255,255,0.12)" stroke-width="2"/>
        <rect x="810" y="90" width="58" height="44" rx="2" fill="rgba(255,255,255,0.10)"/>
        <polygon points="804,90 874,90 839,68" fill="rgba(255,255,255,0.13)"/>
        <rect x="829" y="108" width="15" height="26" rx="1" fill="rgba(0,0,0,0.1)"/>
        <rect x="816" y="98" width="10" height="9" rx="1" fill="rgba(255,255,255,0.15)"/>
        <rect x="848" y="98" width="10" height="9" rx="1" fill="rgba(255,255,255,0.15)"/>
        <rect x="872" y="99" width="17" height="35" rx="3" fill="rgba(255,255,255,0.09)"/>
        <ellipse cx="880" cy="99" rx="8.5" ry="5" fill="rgba(255,255,255,0.12)"/>
        <ellipse cx="940" cy="110" rx="18" ry="24" fill="rgba(255,255,255,0.07)"/>
        <ellipse cx="962" cy="106" rx="14" ry="19" fill="rgba(255,255,255,0.09)"/>
        <rect x="938" y="126" width="4" height="16" fill="rgba(255,255,255,0.06)"/>
        <path d="M430,138 C480,135 530,138 580,135" stroke="rgba(255,255,255,0.08)" stroke-width="2.5" fill="none" stroke-linecap="round"/>
        <path d="M430,145 C480,142 530,145 580,142" stroke="rgba(255,255,255,0.08)" stroke-width="2.5" fill="none" stroke-linecap="round"/>
        <path d="M0,140 C150,132 350,143 550,136 C750,129 950,140 1200,134 L1200,160 L0,160 Z" fill="rgba(0,0,0,0.12)"/>
      </svg>
    </div>
  </section>

  <!-- Stats bar -->
  <div class="stats-bar fade-in">
    <div class="stat">
      <span class="stat-num">{farms.length}</span>
      <span class="stat-label">Local Farms</span>
    </div>
    <div class="stats-divider">|</div>
    <div class="stat">
      <span class="stat-num">{markets.length}</span>
      <span class="stat-label">Farmers Markets</span>
    </div>
    <div class="stats-divider">|</div>
    <div class="stat">
      <span class="stat-num">2×</span>
      <span class="stat-label">Blog Per Week</span>
    </div>
    <div class="stats-divider">|</div>
    <div class="stat">
      <span class="stat-num">4×</span>
      <span class="stat-label">Recipes Per Week</span>
    </div>
  </div>

  <!-- Seasonal strip — labels and pills updated client-side -->
  <div class="seasonal-strip fade-in" id="seasonal-strip">
    <div class="strip-row">
      <span class="strip-label" id="strip-label-current">🌿 In season this month:</span>
      <div class="strip-items" id="strip-items-current">
        {produce.map((item) => (
          <a href={produceLink(item)} class="strip-pill">{item}</a>
        ))}
      </div>
    </div>
    <div class="strip-row strip-row--next">
      <span class="strip-label strip-label--next" id="strip-label-next">🗓 Coming next month:</span>
      <div class="strip-items" id="strip-items-next">
        {nextProduce.map((item) => (
          <a href={produceLink(item)} class="strip-pill strip-pill--next">{item}</a>
        ))}
      </div>
    </div>
  </div>

  <!-- ── 1. UPCOMING LOCAL EVENTS ── -->
  {upcomingEvents.length > 0 && (
    <>
      <div class="wave-divider fade-in">
        <svg viewBox="0 0 1200 64" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none">
          <path d="M0,32 C150,60 350,8 600,36 C850,62 1050,12 1200,36 L1200,64 L0,64 Z" fill="#fffdf0"/>
        </svg>
      </div>
      <div class="section-band fade-in" style="background: linear-gradient(180deg,#fffdf0,#fff8e8); margin:0 -1.5rem; padding:2.5rem 1.5rem 3rem; border-bottom:1px solid #f0e0b0;">
        <div class="section-heading">
          <h2>📅 Upcoming Local Events</h2>
          <a href="/events">All events &rarr;</a>
        </div>
        <div class="grid">
          {upcomingEvents.slice(0, 3).map((event) => (
              <a href={`/events/${event.id}`} class="card card--event hoverable" style="--event-color: #e0a458;" data-event-date={event.data.date.toISOString()}>
                <div style="display:flex; align-items:center; gap:0.5rem; flex-wrap:wrap; margin-bottom:0.5rem;">
                  <span style="background:#fbe9d2; color:#c8853a; border-radius:999px; padding:0.2rem 0.7rem; font-size:0.78rem; font-weight:600;">{event.data.category}</span>
                  <span class="event-countdown-badge" style="display:none; background:#e0a458; color:#fff; border-radius:999px; padding:0.2rem 0.6rem; font-size:0.72rem; font-weight:800; text-transform:uppercase; letter-spacing:0.05em;"></span>
                </div>
                <h3>{event.data.name}</h3>
                <p class="town">📍 {event.data.location}, {event.data.town}</p>
                <p style="font-size:0.88rem; color:var(--muted); margin:0 0 0.5rem;">
                  📅 {event.data.date.toLocaleDateString('en-US',{weekday:'short',month:'short',day:'numeric',timeZone:'UTC'})} &nbsp;·&nbsp; 🕘 {event.data.time}
                </p>
                {event.data.admission && <p style="font-size:0.85rem; margin:0; color:var(--green-dark); font-weight:600;">🎟 {event.data.admission}</p>}
              </a>
          ))}
        </div>
      </div>
    </>
  )}

  <!-- ── 2. FARMERS MARKETS ── -->
  <div class="wave-divider">
    <svg viewBox="0 0 1200 64" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none">
      <path d="M0,36 C180,8 380,56 620,28 C860,2 1050,50 1200,26 L1200,64 L0,64 Z" fill="#edf5ea"/>
    </svg>
  </div>
  <div class="section-band section-band--green fade-in">
    <div class="section-heading">
      <h2>Farmers Markets</h2>
      <a href="/markets">View all {markets.length} &rarr;</a>
    </div>
    <div class="grid">
      {markets.slice(0, 3).map((market) => (
        <a class="card card--market" href="/markets">
          <span class="icon">🧺</span>
          <h3>{market.data.name}</h3>
          <p class="town">{market.data.town}</p>
          <p>{market.data.summary}</p>
        </a>
      ))}
    </div>
  </div>

  <!-- ── 3. FARMS & CSAs ── -->
  <div class="wave-divider">
    <svg viewBox="0 0 1200 64" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none">
      <path d="M0,28 C200,56 400,4 650,32 C900,58 1050,14 1200,30 L1200,64 L0,64 Z" fill="#fbfaf5"/>
    </svg>
  </div>
  <div class="section-band section-band--cream fade-in">
    <div class="section-heading">
      <h2>Farms &amp; CSAs</h2>
      <a href="/farms">View all {farms.length} &rarr;</a>
    </div>
    <div class="grid">
      {farms.slice(0, 3).map((farm) => (
        <a class="card card--farm" href={`/farms/${farm.id}`}>
          <span class="icon">{farmIcon(farm.data.products)}</span>
          <h3>{farm.data.name}</h3>
          <p class="town">{farm.data.town}</p>
          <p>{farm.data.summary}</p>
        </a>
      ))}
    </div>
  </div>

  <!-- ── 4. LATEST FROM THE BLOG ── -->
  <div class="wave-divider">
    <svg viewBox="0 0 1200 64" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none">
      <path d="M0,32 C150,60 350,8 600,36 C850,62 1050,12 1200,36 L1200,64 L0,64 Z" fill="#edf5ea"/>
    </svg>
  </div>
  <div class="section-band section-band--green fade-in">
    <div class="section-heading">
      <h2>Latest from the Blog</h2>
      <a href="/blog">All posts &rarr;</a>
    </div>
    <div class="grid">
      {posts.slice(0, 3).map((post) => (
        <a class="card card--blog" href={`/blog/${post.id}`}>
          <span class="icon">📰</span>
          <h3>{post.data.title}</h3>
          <p>{post.data.description}</p>
        </a>
      ))}
    </div>
  </div>

  <!-- ── 5. LATEST RECIPES ── -->
  <div class="wave-divider">
    <svg viewBox="0 0 1200 64" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none">
      <path d="M0,36 C180,8 380,56 620,28 C860,2 1050,50 1200,26 L1200,64 L0,64 Z" fill="#fbfaf5"/>
    </svg>
  </div>
  <div class="section-band section-band--cream fade-in">
    <div class="section-heading">
      <h2>Latest Recipes</h2>
      <a href="/recipes">All recipes &rarr;</a>
    </div>
    <div class="grid">
      {recipes.slice(0, 3).map((recipe) => (
        <a class="card card--recipe" href={`/recipes/${recipe.id}`}>
          <span class="icon">🍳</span>
          <h3>{recipe.data.title}</h3>
          <p class="town">{recipe.data.season}</p>
          <p>{recipe.data.description}</p>
          <div style="margin-top:0.5rem; display:flex; flex-wrap:wrap; gap:0.3rem;">
            {recipe.data.produce.map((p: string) => <span class="tag">{p}</span>)}
          </div>
        </a>
      ))}
    </div>
  </div>

</Layout>

<script define:vars={{ seasonalProduce, produceSlugMap }}>
(function() {
  const monthNames = ['January','February','March','April','May','June','July','August','September','October','November','December'];
  const month = new Date().getMonth();
  const nextMonth = (month + 1) % 12;

  // Update seasonal strip
  const produce = seasonalProduce[month] || [];
  const nextProduce = seasonalProduce[nextMonth] || [];

  function pillsHTML(items, cls) {
    return items.map(item => {
      const slug = produceSlugMap[item];
      const href = slug ? '/produce/' + slug : '/markets';
      return '<a href="' + href + '" class="strip-pill' + (cls ? ' ' + cls : '') + '">' + item + '</a>';
    }).join('');
  }

  const labelCurrent = document.getElementById('strip-label-current');
  const itemsCurrent = document.getElementById('strip-items-current');
  const labelNext = document.getElementById('strip-label-next');
  const itemsNext = document.getElementById('strip-items-next');

  if (labelCurrent) labelCurrent.textContent = '🌿 In season this ' + monthNames[month] + ':';
  if (itemsCurrent) itemsCurrent.innerHTML = pillsHTML(produce, '');
  if (labelNext) labelNext.textContent = '🗓 Coming in ' + monthNames[nextMonth] + ':';
  if (itemsNext) itemsNext.innerHTML = pillsHTML(nextProduce, 'strip-pill--next');

  // Update event countdown badges
  const today = new Date(); today.setHours(0,0,0,0);
  document.querySelectorAll('[data-event-date]').forEach(card => {
    const eventDate = new Date(card.dataset.eventDate);
    eventDate.setHours(0,0,0,0);
    const days = Math.ceil((eventDate - today) / (1000 * 60 * 60 * 24));
    const badge = card.querySelector('.event-countdown-badge');
    if (badge && days >= 0 && days <= 7) {
      badge.textContent = days === 0 ? 'TODAY!' : days === 1 ? 'Tomorrow!' : 'In ' + days + ' days';
      badge.style.display = 'inline';
    }
  });
})();
</script>
