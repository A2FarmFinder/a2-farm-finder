---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const farms = await getCollection('farms');
const markets = await getCollection('markets');
const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<Layout title="Home">
  <h1>Find local farms, CSAs &amp; farmers markets near Ann Arbor</h1>
  <p>
    A directory of farms, CSA programs, and farmers markets across
    Washtenaw County &mdash; Ann Arbor, Chelsea, Dexter, Saline, Manchester,
    and beyond.
  </p>

  <h2>Latest posts</h2>
  {posts.slice(0, 3).map((post) => (
    <div class="card">
      <h3><a href={`/blog/${post.id}`}>{post.data.title}</a></h3>
      <p>{post.data.description}</p>
    </div>
  ))}

  <h2>Browse</h2>
  <p>
    <a href="/farms">{farms.length} farms &amp; CSAs</a> &middot;
    <a href="/markets">{markets.length} farmers markets</a>
  </p>
</Layout>
