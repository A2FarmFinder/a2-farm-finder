---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const markets = (await getCollection('markets')).sort((a, b) =>
  a.data.name.localeCompare(b.data.name)
);

function mapsUrl(address: string) {
  const clean = address.split(';')[0].replace(/\(.*?\)/g, '').trim();
  return `https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(clean)}`;
}
---

<Layout title="Farmers Markets" description="Farmers market schedules around Ann Arbor, Chelsea, Saline, and Dexter, Michigan.">
  <div class="page-intro">
    <h1>Farmers Markets</h1>
    <p>Weekly farmers market schedules around Washtenaw County.</p>
  </div>

  <!-- What's in season now — content updated client-side to reflect real current month -->
  <div class="card" style="margin-bottom: 2rem; border-left: 4px solid var(--gold);">
    <h2 style="margin-top: 0;" id="market-season-title">🌿 What's at the Market</h2>
    <div id="market-season-content">
      <p>Loading what's in season...</p>
    </div>
    <p style="margin-bottom: 0;"><em>Tip: arrive early — the best vendors sell out by 10am on Saturdays.</em></p>
  </div>

  <!-- First-timer tips -->
  <div class="card" style="margin-bottom: 2rem; background: var(--green-dark); color: #fff;">
    <h2 style="margin-top: 0; color: var(--gold);">First Time at a Farmers Market?</h2>
    <ul style="margin-bottom: 0; color: #fff;">
      <li><strong style="color: var(--gold);">Arrive early.</strong> The best produce goes to early shoppers — aim for opening time.</li>
      <li><strong style="color: var(--gold);">Bring cash.</strong> Most vendors accept cards but cash is faster and always works.</li>
      <li><strong style="color: var(--gold);">Bring your own bags.</strong> You'll buy more than you expect.</li>
      <li><strong style="color: var(--gold);">Talk to the farmers.</strong> Ask what's freshest, how to cook something unfamiliar, or when they expect a crop to come in.</li>
      <li><strong style="color: var(--gold);">SNAP/EBT accepted.</strong> All four Washtenaw County markets accept SNAP/Bridge cards. Ann Arbor and Saline also participate in <strong style="color: var(--gold);">Double Up Food Bucks</strong> — spend $10 in SNAP and get $10 more free for fresh produce.</li>
    </ul>
  </div>

  <div class="grid">
    {markets.map((market) => (
      <div class="card hoverable">
        <span class="icon">🧺</span>
        <h3>{market.data.name}</h3>
        <p class="town">{market.data.town}</p>
        <p>{market.data.summary}</p>
        <ul>
          <li><strong>Schedule:</strong> {market.data.schedule}</li>
          <li><strong>Season:</strong> {market.data.season}</li>
          <li><strong>Address:</strong> {market.data.address}</li>
        </ul>
        <div style="display: flex; gap: 0.5rem; flex-wrap: wrap; margin-top: 0.75rem;">
          {market.data.website && (
            <a href={market.data.website} target="_blank" rel="noopener noreferrer" style="padding: 0.5rem 1.1rem; border-radius: 999px; font-weight: 600; text-decoration: none; background: var(--green-dark); color: #fff; font-size: 0.9rem;">Visit Website →</a>
          )}
          <a href={mapsUrl(market.data.address)} target="_blank" rel="noopener noreferrer" style="padding: 0.5rem 1.1rem; border-radius: 999px; font-weight: 600; text-decoration: none; background: var(--gold); color: var(--green-dark); font-size: 0.9rem;">Get Directions →</a>
        </div>
      </div>
    ))}
  </div>
</Layout>

<script>
(function() {
  const monthNames = ['January','February','March','April','May','June','July','August','September','October','November','December'];
  const month = new Date().getMonth();
  const monthName = monthNames[month];

  const seasonal = {
    0:  { veg: 'Stored root vegetables, greenhouse greens', fruit: 'Winter apples and pears from cold storage', also: 'Farm eggs, local honey, maple syrup, baked goods, and cheese year-round.' },
    1:  { veg: 'Greenhouse lettuce, spinach, and herbs', fruit: 'Winter apples from cold storage', also: 'Farm eggs, honey, dried beans, and preserves.' },
    2:  { veg: 'Greenhouse greens, spinach, early herbs', fruit: 'Maple syrup (peak season!)', also: 'Farm eggs, honey, seedlings starting to appear, baked goods.' },
    3:  { veg: 'Asparagus, spinach, lettuce, rhubarb, radishes, early herbs', fruit: 'Rhubarb — the first fruit of spring', also: 'Plant seedlings, transplants, farm eggs, and honey.' },
    4:  { veg: 'Asparagus, snap peas, lettuce, spinach, kale, chard, radishes, herbs, scallions', fruit: 'Strawberries arriving late May — grab them fast', also: 'Seedlings and transplants, cut flowers, farm eggs, honey.' },
    5:  { veg: 'Asparagus (late June), spinach, lettuce, arugula, radishes, peas, scallions, kale, chard, herbs, and the first zucchini', fruit: 'Strawberries at peak season — don\'t miss them, they go fast', also: 'Transplants and seedlings, cut flowers, fresh eggs, honey, and baked goods year-round.' },
    6:  { veg: 'Zucchini, green beans, cucumbers, kale, chard, herbs, scallions, and the first tomatoes', fruit: 'Blueberries arriving mid-July — one of the best Michigan crops', also: 'Cut flowers, sweet corn starting late July, farm eggs, honey, and baked goods.' },
    7:  { veg: 'Tomatoes, sweet corn, peppers, eggplant, cucumbers, zucchini, green beans, herbs, and the first winter squash', fruit: 'Blueberries, peaches, and melons — peak summer abundance', also: 'Cut flowers, farm eggs, honey, and baked goods.' },
    8:  { veg: 'Tomatoes, peppers, winter squash, sweet potatoes, garlic, kale, chard, and beans', fruit: 'Apples beginning, late peaches and melons', also: 'Dried flowers, farm eggs, honey, and canned goods.' },
    9:  { veg: 'Winter squash, pumpkins, sweet potatoes, kale, Brussels sprouts, carrots, beets, and garlic', fruit: 'Apples — peak Michigan apple season with dozens of varieties', also: 'Cider, gourds, dried flowers, farm eggs, honey, and baked goods.' },
    10: { veg: 'Root vegetables, kale, Brussels sprouts, cabbage, turnips, beets, and storage squash', fruit: 'Late apples and pears from cold storage', also: 'Cider, dried herbs, farm eggs, honey, and baked goods.' },
    11: { veg: 'Storage root vegetables, greenhouse greens, and winter kale', fruit: 'Stored apples and pears', also: 'Farm eggs, local honey, maple syrup pre-orders, baked goods, and holiday wreaths.' },
  };

  const s = seasonal[month] || seasonal[6];

  document.getElementById('market-season-title').textContent = '🌿 What\'s at the Market in ' + monthName;
  document.getElementById('market-season-content').innerHTML =
    '<p>' + monthName + ' is a great time to visit the farmers market. Look for:</p>' +
    '<p><strong>Vegetables:</strong> ' + s.veg + '.</p>' +
    '<p><strong>Fruits:</strong> ' + s.fruit + '.</p>' +
    '<p><strong>Also look for:</strong> ' + s.also + '</p>';
})();
</script>
