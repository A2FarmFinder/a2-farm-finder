---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const markets = (await getCollection('markets')).sort((a, b) =>
  a.data.name.localeCompare(b.data.name)
);
---

<Layout title="Farmers Markets" description="Farmers market schedules around Ann Arbor, Chelsea, and Saline.">
  <div class="page-intro">
    <h1>Farmers Markets</h1>
    <p>Weekly farmers market schedules around Washtenaw County.</p>
  </div>

  <div class="grid">
    {markets.map((market) => (
      <div class="card hoverable">
        <span class="icon">🧺</span>
        <h3>{market.data.name}</h3>
        <p class="town">{market.data.town}</p>
        <p>{market.data.summary}</p>
        <ul>
          <li><strong>Schedule:</strong> {market.data.schedule}</li>
          <li><strong>Season:</strong> {market.data.season}</li>
          <li><strong>Address:</strong> {market.data.address}</li>
        </ul>
        {market.data.website && (
          <a href={market.data.website} target="_blank" rel="noopener noreferrer" style="margin-top: 0.75rem; display: inline-block; padding: 0.5rem 1.1rem; border-radius: 999px; font-weight: 600; text-decoration: none; background: var(--green-dark); color: #fff; font-size: 0.9rem;">Visit Market Website →</a>
        )}
      </div>
    ))}
  </div>
</Layout>
