---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<Layout title="Blog" description="Seasonal guides and tips for buying local around Ann Arbor.">
  <div class="page-intro">
    <h1>Blog</h1>
    <p>Seasonal guides and tips for buying local around Washtenaw County.</p>
  </div>

  <div class="grid">
    {posts.map((post) => (
      <a class="card" href={`/blog/${post.id}`}>
        <span class="icon">📰</span>
        <h3>{post.data.title}</h3>
        <p class="town">{post.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric', timeZone: 'UTC' })}</p>
        <p>{post.data.description}</p>
      </a>
    ))}
  </div>
</Layout>
