---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<Layout title="Blog" description="Seasonal guides and tips for buying local around Ann Arbor.">
  <h1>Blog</h1>

  {posts.map((post) => (
    <div class="card">
      <h3><a href={`/blog/${post.id}`}>{post.data.title}</a></h3>
      <p>{post.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</p>
      <p>{post.data.description}</p>
    </div>
  ))}
</Layout>
