<script define:vars={{ scavengerItems: scavengerItems }}>
// ══════════════════════════════════
// SCAVENGER HUNT — client-side month detection
// ══════════════════════════════════
(function() {
  const monthNames = ['January','February','March','April','May','June','July','August','September','October','November','December'];
  const month = new Date().getMonth();
  const monthName = monthNames[month];
  const hunt = scavengerItems[month] || scavengerItems[6];

  // Update title
  const titleEl = document.getElementById('hunt-title');
  if (titleEl) titleEl.textContent = monthName + ' Farmers Market Scavenger Hunt!';

  // Re-render grid with correct month's items
  const grid = document.getElementById('hunt-grid');
  if (grid) {
    grid.innerHTML = hunt.map((item, i) =>
      `<button class="hunt-item" data-index="${i}" data-fact="${item.fact.replace(/"/g,'&quot;')}" aria-label="Mark ${item.name} as found">
        <span class="hunt-emoji">${item.emoji}</span>
        <span class="hunt-name">${item.name}</span>
        <span class="hunt-check">✓</span>
      </button>`
    ).join('');
  }

  // Update found count label
  const foundCountEl = document.getElementById('hunt-found');
  if (foundCountEl) foundCountEl.textContent = '0';

  const huntLength = hunt.length;
  const STORAGE_KEY = 'a2ff_hunt_' + month + '_' + new Date().getFullYear();
  let found = JSON.parse(localStorage.getItem(STORAGE_KEY) || '[]');

  function updateHuntUI() {
    const items = document.querySelectorAll('.hunt-item');
    const fill = document.getElementById('hunt-fill');
    const foundEl = document.getElementById('hunt-found');
    const starEl = document.getElementById('hunt-star');
    const celebration = document.getElementById('hunt-celebration');

    items.forEach((item, i) => {
      if (found.includes(i)) item.classList.add('found');
    });

    const pct = (found.length / huntLength) * 100;
    if (fill) fill.style.width = pct + '%';
    if (foundEl) foundEl.textContent = found.length;
    if (starEl) starEl.style.display = found.length > 0 ? 'inline' : 'none';
    if (celebration) celebration.style.display = found.length === huntLength ? 'block' : 'none';
    if (found.length === huntLength) launchConfetti();
  }

  function bindHuntItems() {
    document.querySelectorAll('.hunt-item').forEach((item, i) => {
      item.addEventListener('click', function() {
        if (found.includes(i)) {
          found = found.filter(f => f !== i);
          item.classList.remove('found');
          document.getElementById('hunt-fact-box').style.display = 'none';
        } else {
          found.push(i);
          item.classList.add('found');
          const fact = item.dataset.fact;
          const factBox = document.getElementById('hunt-fact-box');
          const factText = document.getElementById('hunt-fact-text');
          factText.textContent = item.querySelector('.hunt-name').textContent + ': ' + fact;
          factBox.style.display = 'flex';
        }
        localStorage.setItem(STORAGE_KEY, JSON.stringify(found));
        updateHuntUI();
      });
    });
  }
  bindHuntItems();

  document.getElementById('hunt-reset')?.addEventListener('click', () => {
    found = [];
    localStorage.removeItem(STORAGE_KEY);
    document.querySelectorAll('.hunt-item').forEach(i => i.classList.remove('found'));
    document.getElementById('hunt-fact-box').style.display = 'none';
    document.getElementById('hunt-celebration').style.display = 'none';
    updateHuntUI();
  });

  updateHuntUI();
})();

// ══════════════════════════════════
// QUIZ
// ══════════════════════════════════
(function() {
  const questions = [
    { emoji:'🥕', name:'Carrot',       answer:'underground', fact:'Carrots are roots that store energy for the plant underground. Ancient carrots were actually purple!' },
    { emoji:'🍅', name:'Tomato',       answer:'plant',       fact:'Tomatoes are technically a fruit because they have seeds inside. There are over 10,000 varieties!' },
    { emoji:'🍎', name:'Apple',        answer:'tree',        fact:'It takes 4-5 years for an apple tree to make its first fruit. Some trees live over 100 years!' },
    { emoji:'🌽', name:'Corn',         answer:'plant',       fact:'Each ear of corn always has an even number of rows — scientists aren\'t totally sure why!' },
    { emoji:'🎃', name:'Pumpkin',      answer:'plant',       fact:'Pumpkins grow on vines that can reach 30 feet long! The biggest pumpkin ever weighed 2,700 lbs!' },
    { emoji:'🫐', name:'Blueberry',    answer:'tree',        fact:'Blueberries grow on bushes and are one of the only naturally blue foods in the world!' },
    { emoji:'🍓', name:'Strawberry',   answer:'plant',       fact:'Strawberries are the only fruit with seeds on the OUTSIDE — about 200 seeds per berry!' },
    { emoji:'🥔', name:'Potato',       answer:'underground', fact:'Potatoes are not roots — they\'re tubers, which are like underground storage tanks for the plant!' },
    { emoji:'🍑', name:'Peach',        answer:'tree',        fact:'Peaches are related to roses! They\'re in the same plant family as roses, almonds, and cherries.' },
    { emoji:'🥒', name:'Cucumber',     answer:'plant',       fact:'Cucumbers are 96% water — they\'re great for staying hydrated on a hot summer day!' },
  ];

  const answerLabels = {
    underground: { text: '🌍 Underground', sub: 'Hidden in the soil' },
    plant:       { text: '🌿 On a plant or vine', sub: 'Grows above ground' },
    tree:        { text: '🌳 On a tree or bush', sub: 'Up in the branches' },
  };

  let current = 0, score = 0, answered = false;

  function shuffle(arr) { return arr.sort(() => Math.random() - 0.5); }

  function loadQuestion() {
    const q = questions[current];
    answered = false;
    document.getElementById('quiz-emoji').textContent = q.emoji;
    document.getElementById('quiz-item').textContent = q.name;
    document.getElementById('quiz-fill').style.width = (current / questions.length * 100) + '%';
    document.getElementById('q-num').textContent = current + 1;
    document.getElementById('quiz-feedback').style.display = 'none';

    const opts = document.querySelectorAll('.quiz-opt');
    opts.forEach(opt => {
      opt.classList.remove('correct', 'wrong');
      opt.disabled = false;
      const key = opt.dataset.answer;
      opt.innerHTML = answerLabels[key].text + '<br><small>' + answerLabels[key].sub + '</small>';
    });

    // Animate the emoji
    const emojiEl = document.getElementById('quiz-emoji');
    emojiEl.style.animation = 'none';
    requestAnimationFrame(() => { emojiEl.style.animation = 'pop 0.4s cubic-bezier(.34,1.56,.64,1)'; });
  }

  function showResult() {
    document.getElementById('quiz-container').querySelector('.quiz-progress').style.display = 'none';
    document.getElementById('quiz-card').style.display = 'none';
    const result = document.getElementById('quiz-result');
    result.style.display = 'block';
    document.getElementById('result-score').textContent = score;

    let emoji, title, message;
    if (score === 10) {
      emoji = '🏆'; title = 'PERFECT SCORE!';
      message = 'You\'re a farming genius! You know exactly where all your food comes from!';
      launchConfetti();
    } else if (score >= 7) {
      emoji = '🌟'; title = 'Amazing!';
      message = 'You really know your fruits and veggies! Visit the farmers market to see them growing!';
    } else if (score >= 4) {
      emoji = '🌱'; title = 'Good Job!';
      message = 'You\'re learning! Visit the farmers market to discover more about how food grows.';
    } else {
      emoji = '🥕'; title = 'Keep Learning!';
      message = 'That\'s okay — now you know more! Ask a farmer at the market to teach you more!';
    }
    document.getElementById('result-emoji').textContent = emoji;
    document.getElementById('result-title').textContent = title;
    document.getElementById('result-message').textContent = message;
  }

  document.querySelectorAll('.quiz-opt').forEach(btn => {
    btn.addEventListener('click', function() {
      if (answered) return;
      answered = true;
      const q = questions[current];
      const chosen = this.dataset.answer;
      const isCorrect = chosen === q.answer;

      document.querySelectorAll('.quiz-opt').forEach(b => {
        b.disabled = true;
        if (b.dataset.answer === q.answer) b.classList.add('correct');
      });
      if (!isCorrect) this.classList.add('wrong');
      if (isCorrect) score++;

      const fb = document.getElementById('quiz-feedback');
      document.getElementById('quiz-feedback-icon').textContent = isCorrect ? '✅' : '❌';
      document.getElementById('quiz-feedback-text').textContent = isCorrect ? 'That\'s right!' : 'Not quite — the answer is: ' + answerLabels[q.answer].text;
      document.getElementById('quiz-fun-fact').textContent = '🌟 Fun fact: ' + q.fact;
      fb.style.display = 'block';
    });
  });

  document.getElementById('quiz-next')?.addEventListener('click', () => {
    current++;
    if (current < questions.length) loadQuestion();
    else showResult();
  });

  document.getElementById('quiz-reset')?.addEventListener('click', () => {
    current = 0; score = 0; answered = false;
    document.getElementById('quiz-result').style.display = 'none';
    document.getElementById('quiz-card').style.display = 'block';
    document.querySelector('.quiz-progress').style.display = 'block';
    loadQuestion();
  });

  loadQuestion();
})();

// ══════════════════════════════════
// MATCHING GAME
// ══════════════════════════════════
(function() {
  const pairs = [
    { id: 'cow',     emoji: '🐄', label: 'Cow',     type: 'animal' },
    { id: 'milk',    emoji: '🥛', label: 'Milk',    type: 'product', match: 'cow' },
    { id: 'chicken', emoji: '🐔', label: 'Chicken', type: 'animal' },
    { id: 'eggs',    emoji: '🥚', label: 'Eggs',    type: 'product', match: 'chicken' },
    { id: 'bee',     emoji: '🐝', label: 'Bee',     type: 'animal' },
    { id: 'honey',   emoji: '🍯', label: 'Honey',   type: 'product', match: 'bee' },
    { id: 'goat',    emoji: '🐐', label: 'Goat',    type: 'animal' },
    { id: 'cheese',  emoji: '🧀', label: 'Cheese',  type: 'product', match: 'goat' },
  ];

  // Also set up match map
  const matchMap = { cow:'milk', milk:'cow', chicken:'eggs', eggs:'chicken', bee:'honey', honey:'bee', goat:'cheese', cheese:'goat' };

  let selected = null, matches = 0, tries = 0;

  function buildGrid() {
    const grid = document.getElementById('match-grid');
    grid.innerHTML = '';
    selected = null; matches = 0; tries = 0;
    document.getElementById('match-count').textContent = 0;
    document.getElementById('match-tries').textContent = 0;
    document.getElementById('match-celebration').style.display = 'none';

    const shuffled = [...pairs].sort(() => Math.random() - 0.5);
    shuffled.forEach(card => {
      const el = document.createElement('button');
      el.className = 'match-card ' + card.type;
      el.dataset.id = card.id;
      el.innerHTML = card.emoji + '<span class="card-label">' + card.label + '</span>';
      el.addEventListener('click', onCardClick);
      grid.appendChild(el);
    });
  }

  function onCardClick() {
    if (this.classList.contains('matched') || this === selected) return;

    if (!selected) {
      selected = this;
      this.classList.add('selected');
      return;
    }

    tries++;
    document.getElementById('match-tries').textContent = tries;

    const a = selected.dataset.id;
    const b = this.dataset.id;

    if (matchMap[a] === b) {
      // Match!
      [selected, this].forEach(el => {
        el.classList.remove('selected');
        el.classList.add('matched');
        el.disabled = true;
      });
      matches++;
      document.getElementById('match-count').textContent = matches;
      selected = null;

      if (matches === 4) {
        document.getElementById('match-celebration').style.display = 'block';
        launchConfetti();
      }
    } else {
      // Wrong
      const wrongCards = [selected, this];
      this.classList.add('wrong');
      selected.classList.add('wrong');
      selected.classList.remove('selected');
      selected = null;

      setTimeout(() => {
        wrongCards.forEach(el => el.classList.remove('wrong'));
      }, 700);
    }
  }

  document.getElementById('match-reset')?.addEventListener('click', buildGrid);
  buildGrid();
})();

// ══════════════════════════════════
// CONFETTI
// ══════════════════════════════════
function launchConfetti() {
  const container = document.getElementById('confetti-container');
  const colors = ['#F9C946','#F07F3C','#E8445A','#4AABE8','#9B59B6','#5CB85C','#fff'];
  for (let i = 0; i < 80; i++) {
    const piece = document.createElement('div');
    piece.className = 'confetti-piece';
    piece.style.left = Math.random() * 100 + 'vw';
    piece.style.background = colors[Math.floor(Math.random() * colors.length)];
    piece.style.width = (8 + Math.random() * 8) + 'px';
    piece.style.height = (8 + Math.random() * 12) + 'px';
    piece.style.borderRadius = Math.random() > 0.5 ? '50%' : '2px';
    piece.style.animationDuration = (2 + Math.random() * 2) + 's';
    piece.style.animationDelay = Math.random() * 0.5 + 's';
    container.appendChild(piece);
    setTimeout(() => piece.remove(), 4500);
  }
}
</script>
